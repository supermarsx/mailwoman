// The FROZEN `mailwoman:plugin` WIT world (plan §2.1, SPEC §22/§7.5).
//
// Authored by the scaffolder gate (t7-e0). This is the ABI contract every plugin
// (bridges e10/e11/e12, LanguageTool e13) and the host (e1) build against.
// **Frozen at approval** — changing a shape here requires the coordinator to
// re-broadcast (the plugin↔host interchangeability contract).
//
// Design invariants:
//   * DENY-BY-DEFAULT: a guest can do NOTHING beyond what the host imports below
//     expose, and the host gates each import against the plugin's manifest grant
//     (capabilities + `net_allowlist`). No ambient WASI filesystem/clock/random/net.
//   * Transport is HOST-MEDIATED: a guest never opens a socket — it calls
//     `host.http-fetch`, which the host runs over its own `reqwest`(rustls) and
//     enforces the `net_allowlist` on. This keeps the sandbox intact for bridges.
//   * The `account-backend` export MIRRORS `mw_engine::AccountBackend` (async +
//     a change stream) so a plugin backend is indistinguishable from `mw-imap`
//     once adapted by the host (plan §6.5). e1 owns the async/stream mapping (R1).

// ── t10 (26.10) PIM/parity extension — SECOND-WORLD fallback (plan §5, §10 R1) ──
// The package version + `world plugin` + every 0.1.0 interface (`types`, `host`,
// `account-backend`, …) below are **BYTE-UNCHANGED**. t10 adds three OPTIONAL guest
// interfaces — `calendar`, `tasks`, `bridge-parity` — and a SECOND world
// `plugin-pim` (at the bottom) that `include`s `world plugin` and additionally
// exports the three.
//
// WHY the second world instead of adding the exports to `world plugin` + bumping to
// @0.2.0 (the plan's §2.1 first choice): bumping the package to @0.2.0 renames every
// interface id to `…@0.2.0`, and wasmtime's semver-aware component linker treats a
// 0.1.x→0.2.0 change as INCOMPATIBLE — so the committed @0.1.0 bridge/LanguageTool/
// Nextcloud `.wasm` fixtures (which import `mailwoman:plugin/host@0.1.0`) FAIL to
// link against a host that now provides `host@0.2.0` (proven: `bridge-ews` jail-load
// tests broke). Keeping the package at @0.1.0 and adding a separate world keeps those
// fixtures loading unchanged while PIM-capable guests target `plugin-pim`.
//
// Host contract (e1): a PIM guest built for `plugin-pim` also exports everything
// `world plugin` requires, so the existing host `bindgen!({world: "plugin"})` loads
// it unchanged; e1 adds a probe that additionally looks up the `calendar`/`tasks`/
// `bridge-parity` exports (present ⇒ bind; absent or `supports-*() -> false` ⇒ the
// engine's byte-unchanged standards fallback). e5 wires engine routing.
package mailwoman:plugin@0.1.0;

// ── Shared value types ────────────────────────────────────────────────────────
interface types {
    // Coarse, protocol-agnostic error mirroring `mw_engine::EngineError`.
    variant plugin-error {
        protocol(string),
        auth(string),
        transport(string),
        unsupported(string),
        mailbox-not-found(string),
        limit-exceeded(string),
        capability-denied(string),
        other(string),
    }

    record mailbox-ref {
        name: string,
        uidvalidity: u32,
    }

    // Server-authoritative flags/keywords (mirrors `mw_engine::Flag`).
    variant flag {
        seen,
        answered,
        flagged,
        deleted,
        draft,
        recent,
        keyword(string),
    }

    // A backend message reference (opaque to the engine's stable ids).
    record message-ref {
        // Opaque per-backend coordinate (e.g. serialized IMAP uid or Graph id).
        raw: string,
        mailbox: mailbox-ref,
    }

    record raw-message {
        message-ref: message-ref,
        raw: list<u8>,
        // NB: `flags` is a reserved WIT keyword (declares a `flags` type), so the
        // field is named `msg-flags` (t7-e1 fix — the e0 draft used `flags`, which a
        // real WIT parser rejects; the scaffold never built to wasm so it went
        // unnoticed). Adapts to `mw_engine::RawMessage.flags` host-side.
        msg-flags: list<flag>,
        internaldate: option<string>,
    }

    record mailbox {
        mailbox-ref: mailbox-ref,
        // JMAP special-use role, lowercased ("inbox"|"archive"|... |"none").
        role: string,
        parent: option<string>,
        total: u32,
        unread: u32,
    }

    // Feature flags a backend advertises, incl. the optional bridge-native caps
    // (reactions/voting/recall/focused-sync) the engine prefers when present.
    record backend-caps {
        idle: bool,
        move-cap: bool,
        // Optional bridge-native Outlook-parity capabilities (plan §2.5).
        reactions: bool,
        voting: bool,
        recall: bool,
        focused-sync: bool,
    }

    // An opaque, backend-chosen sync cursor the engine persists verbatim.
    record sync-cursor {
        opaque: list<u8>,
    }

    record mailbox-delta {
        added: list<message-ref>,
        removed: list<message-ref>,
        // (ref, new-full-flag-set) pairs.
        flag-changes: list<tuple<message-ref, list<flag>>>,
        next-cursor: sync-cursor,
    }

    // A change event a backend watch loop emits (mirrors `mw_engine::ChangeEvent`).
    variant change-event {
        mailbox-changed(mailbox-ref),
        disconnected,
    }
}

// ── Host imports (capability-gated; deny-by-default) ──────────────────────────
interface host {
    use types.{plugin-error};

    record http-request {
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    }
    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    enum log-level { error, warn, info, debug, trace }

    // Outbound HTTP, host-mediated. The host ENFORCES the plugin's `net_allowlist`
    // (a URL outside it ⇒ `capability-denied`). The guest never opens a socket.
    http-fetch: func(req: http-request) -> result<http-response, plugin-error>;

    // Acquire an OAuth token for the bound account (Graph/Gmail device/auth-code).
    oauth-token: func(account: string) -> result<string, plugin-error>;

    // Scoped KV scratch (namespaced per plugin; `store:kv-scoped` capability).
    kv-get: func(key: string) -> option<list<u8>>;
    kv-put: func(key: string, value: list<u8>);

    // NO-CONTENT logging floor: level + an opaque message; never mail content.
    log: func(level: log-level, message: string);

    // Ambient time/random are DENIED by default — these are the only sanctioned
    // sources, host-provided so they remain governable.
    now: func() -> u64;                 // unix millis
    random: func(len: u32) -> list<u8>;
}

// ── Guest exports (each optional, capability-gated) ───────────────────────────

// The account-backend seam (§6.5) — mirrors `mw_engine::AccountBackend`. e1 maps
// the async/stream shape across the WASI-p2 boundary (plan §6 R1).
interface account-backend {
    use types.{backend-caps, mailbox, mailbox-ref, message-ref, raw-message,
               sync-cursor, mailbox-delta, flag, change-event, plugin-error};

    capabilities: func() -> result<backend-caps, plugin-error>;
    list-mailboxes: func() -> result<list<mailbox>, plugin-error>;
    sync-mailbox: func(mbox: mailbox-ref, cursor: sync-cursor)
        -> result<mailbox-delta, plugin-error>;
    fetch-raw: func(refs: list<message-ref>) -> result<list<raw-message>, plugin-error>;
    store-flags: func(refs: list<message-ref>, add: list<flag>, remove: list<flag>)
        -> result<_, plugin-error>;
    move-messages: func(refs: list<message-ref>, to: mailbox-ref)
        -> result<_, plugin-error>;
    submit: func(mbox: mailbox-ref, raw: list<u8>, msg-flags: list<flag>)
        -> result<message-ref, plugin-error>;
    // Drain any change events observed since the last call (IMAP IDLE / provider
    // delta-query equivalent). The host adapter drives this on its own cadence and
    // republishes events onto the engine's `ChangeSink` (see `AccountBackend::watch`).
    //
    // NOTE (t7-e1, frozen-ABI refinement — coordinator re-broadcast): the e0 draft
    // modeled this as `changes-stream: func() -> stream<change-event>`. e1 replaced
    // the WASI-p2 async `stream<>` with this synchronous poll (R1 mitigation): (1) it
    // keeps the whole ABI on the STABLE synchronous component model — the async
    // `stream`/`future` types are gated behind wasmtime's unstable
    // `component-model-async` feature, which would enlarge the trust surface of the
    // security core; (2) HTTP bridges (Graph/Gmail/EWS, e10–e12) sync via periodic
    // delta/history queries, not a server push socket, so a host-driven poll is the
    // natural shape anyway. The host still runs an async loop (wasmtime `async`
    // config + epoch preemption); only the guest ABI is a plain function.
    poll-changes: func() -> result<list<change-event>, plugin-error>;
}

// Message in/out pipeline hooks (§22).
interface message-pipeline {
    use types.{plugin-error};
    message-in: func(raw: list<u8>) -> result<list<u8>, plugin-error>;
    message-out: func(raw: list<u8>) -> result<list<u8>, plugin-error>;
}

// Address-book source (§13).
interface addrbook-source {
    use types.{plugin-error};
    search: func(query: string) -> result<list<string>, plugin-error>;
}

// Autoconfig source.
interface autoconfig-source {
    use types.{plugin-error};
    lookup: func(email: string) -> result<option<string>, plugin-error>;
}

// DLP detector (§10.8).
interface dlp-detect {
    use types.{plugin-error};
    // Returns detector verdict strings for a candidate body.
    detect: func(body: list<u8>) -> result<list<string>, plugin-error>;
}

// Spam action (§10.8).
interface spam-action {
    use types.{plugin-error};
    classify: func(raw: list<u8>) -> result<string, plugin-error>;
}

// ── Optional PIM / Outlook-parity interfaces (t10 additive; exported by the
// `plugin-pim` world at the bottom, NOT by `world plugin`) ─────────────────────
//
// Each is an OPTIONAL guest export probed at load (plan §5). A backend that does
// not implement one exports a trivial `supports-*() -> false` (its data funcs may
// return `unsupported`); the host binds nothing and the engine falls back to the
// standards path (byte-unchanged). `types.backend-caps` is NOT modified: calendar/
// tasks presence is advertised by the new `supports-calendar`/`supports-tasks`
// funcs; the coarse reactions/voting/recall/focused-sync bools already in
// `backend-caps` stay the account-level advertisement, and `bridge-parity`'s own
// `supports-*` funcs are the per-interface confirmation e1 probes.

// Calendar seam (SPEC §6.5/§11). iCalendar (RFC 5545) text crosses the boundary —
// the engine already speaks it, so no structured event model is duplicated here.
interface calendar {
    use types.{sync-cursor, plugin-error};

    // A calendar collection the backend exposes.
    record cal-info {
        // Opaque per-backend id.
        id: string,
        name: string,
        // JMAP-ish role/kind, lowercased ("calendar"|"birthdays"|... |"none").
        role: string,
        read-only: bool,
    }

    // A bookable room / resource (Graph/EWS find-rooms).
    record room-info {
        address: string,
        name: string,
        capacity: option<u32>,
    }

    // A calendar event carried as its VEVENT serialization plus coarse coords.
    record event-info {
        // Opaque per-backend id.
        id: string,
        calendar-id: string,
        // RFC 5545 VEVENT text.
        ical: string,
        // RFC3339 window (option for floating / all-day / open-ended).
        start: option<string>,
        end: option<string>,
    }

    // A delta of event changes since an opaque cursor.
    record event-delta {
        changed: list<event-info>,
        // Opaque per-backend ids removed since the cursor.
        removed: list<string>,
        next-cursor: sync-cursor,
    }

    // Whether this guest implements calendar for the bound account (probe gate).
    supports-calendar: func() -> bool;
    list-calendars: func() -> result<list<cal-info>, plugin-error>;
    sync-events: func(calendar-id: string, cursor: sync-cursor)
        -> result<event-delta, plugin-error>;
    find-rooms: func() -> result<list<room-info>, plugin-error>;
    // Free/busy for a principal over [start,end] (RFC3339) as VFREEBUSY text.
    get-schedule: func(who: string, start: string, end: string)
        -> result<string, plugin-error>;
}

// Tasks / to-do seam (SPEC §6.5/§12). VTODO (RFC 5545) text crosses the boundary.
interface tasks {
    use types.{sync-cursor, plugin-error};

    record task-info {
        // Opaque per-backend id.
        id: string,
        list-id: string,
        // RFC 5545 VTODO text.
        ical: string,
        completed: bool,
    }

    record task-delta {
        changed: list<task-info>,
        removed: list<string>,
        next-cursor: sync-cursor,
    }

    supports-tasks: func() -> bool;
    list-tasks: func() -> result<list<task-info>, plugin-error>;
    sync-tasks: func(list-id: string, cursor: sync-cursor)
        -> result<task-delta, plugin-error>;
    complete: func(id: string) -> result<_, plugin-error>;
}

// Outlook-parity seam (SPEC §10.3/§22): reactions, voting buttons, recall, and
// Focused-Inbox sync. `message-ref` is the same opaque backend coordinate the
// account-backend uses.
interface bridge-parity {
    use types.{message-ref, plugin-error};

    record reaction {
        actor: string,
        emoji: string,
    }

    // NB: `option` is a reserved WIT keyword, so the voting field/param is `choice`.
    record vote-tally {
        choice: string,
        count: u32,
    }

    // Mirrors `mw_engine::v7::RecallOutcome` (§10.3 honesty matrix): the bridge
    // NEVER claims more than the backend actually delivered.
    variant recall-outcome {
        requested,
        unsupported,
        failed(string),
    }

    variant focused-state {
        focused,
        other,
    }

    supports-reactions: func() -> bool;
    supports-voting: func() -> bool;
    supports-recall: func() -> bool;
    supports-focused: func() -> bool;

    set-reaction: func(msg: message-ref, emoji: string, add: bool)
        -> result<_, plugin-error>;
    get-reactions: func(msg: message-ref) -> result<list<reaction>, plugin-error>;

    cast-vote: func(msg: message-ref, choice: string) -> result<_, plugin-error>;
    tally: func(msg: message-ref) -> result<list<vote-tally>, plugin-error>;

    recall: func(msg: message-ref) -> result<recall-outcome, plugin-error>;

    get-focused: func(msg: message-ref) -> result<focused-state, plugin-error>;
    set-focused: func(msg: message-ref, focused: bool) -> result<_, plugin-error>;
}

world plugin {
    import host;

    // Every export is OPTIONAL — a plugin implements only the hooks its manifest
    // capabilities declare. The host instantiates and calls only the granted ones.
    export account-backend;
    export message-pipeline;
    export addrbook-source;
    export autoconfig-source;
    export dlp-detect;
    export spam-action;
}

// ── t10 PIM/parity world (second-world fallback; plan §5, §10 R1) ──────────────
// A superset of `world plugin`: it `include`s every import/export of `plugin` (so a
// component built for `plugin-pim` still satisfies the existing host
// `bindgen!({world: "plugin"})` and loads unchanged) and ADDITIONALLY exports the
// three optional PIM/parity interfaces. PIM-capable guests (the Graph/EWS/Gmail
// bridges, e2/e3/e4) target this world; account-backend-only / 0.1.0 plugins keep
// targeting `world plugin`. The package stays @0.1.0 so committed @0.1.0 fixtures
// keep linking (`host@0.1.0` unchanged). e1 probes the three exports at load.
world plugin-pim {
    include plugin;

    export calendar;
    export tasks;
    export bridge-parity;
}
