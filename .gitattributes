# Enforce LF for files that run on Linux (CI + containers), regardless of the
# committer's OS. Shell scripts with CRLF break the shebang; Dockerfiles and
# compose/CI YAML are consumed by Linux tooling.
*.sh            text eol=lf
Dockerfile      text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.toml          text eol=lf
*.service       text eol=lf
.dockerignore   text eol=lf
.gitattributes  text eol=lf
# Mail-server configs + seed fixtures bind-mounted into Linux containers
# (Dovecot conf/passwd, RFC822 seeds). CRLF here breaks config parsing.
*.conf                            text eol=lf
*.eml                             text eol=lf
scripts/dovecot/mailwoman-users   text eol=lf
# Radicale config + htpasswd (extensionless) bind-mounted into the Linux
# container; CRLF would corrupt the ini parse / the testpass credential.
scripts/radicale/config           text eol=lf
scripts/radicale/users            text eol=lf
