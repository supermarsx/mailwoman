{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mailwoman",
  "version": "26.14.0",
  "identifier": "com.mailwoman.desktop",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Mailwoman thin desktop shell",
    "longDescription": "Mailwoman desktop shell (Tauri v2): the same web SPA the server serves, plus native OS integration and an optional self-contained local server. Thin client — no protocol logic in the shell.",
    "resources": ["resources/mw-server*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "Mailwoman",
    "homepage": "https://mailwoman.example",
    "license": "AGPL-3.0-or-later",
    "linux": {
      "deb": {
        "section": "mail",
        "priority": "optional",
        "depends": []
      },
      "rpm": {
        "release": "1",
        "epoch": 0,
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "windows": {
      "certificateThumbprint": "HUMAN_PROVIDE_WINDOWS_CODE_SIGNING_THUMBPRINT__see_docs/deploy/packaging.md",
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true,
      "entitlements": "../../../packaging/macos/entitlements.plist",
      "signingIdentity": "HUMAN_PROVIDE_APPLE_DEVELOPER_ID_APPLICATION_CERT__see_packaging/macos/notarize.md",
      "providerShortName": "HUMAN_PROVIDE_APPLE_TEAM_ID__see_packaging/macos/notarize.md",
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "HUMAN_PROVIDE_MINISIGN_UPDATER_PUBKEY__see_packaging/updater/README.md",
      "endpoints": [
        "https://releases.mailwoman.example/updater/stable/{{target}}/{{arch}}/{{current_version}}",
        "https://releases.mailwoman.example/updater/staging/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
