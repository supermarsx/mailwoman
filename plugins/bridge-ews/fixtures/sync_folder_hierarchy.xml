<?xml version="1.0" encoding="utf-8"?>
<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"
               xmlns:m="http://schemas.microsoft.com/exchange/services/2006/messages"
               xmlns:t="http://schemas.microsoft.com/exchange/services/2006/types">
  <soap:Body>
    <m:SyncFolderHierarchyResponse>
      <m:ResponseMessages>
        <m:SyncFolderHierarchyResponseMessage ResponseClass="Success">
          <m:ResponseCode>NoError</m:ResponseCode>
          <m:SyncState>H-STATE-1</m:SyncState>
          <m:IncludesLastFolderInRange>true</m:IncludesLastFolderInRange>
          <m:Changes>
            <t:Create>
              <t:Folder>
                <t:FolderId Id="FLD-INBOX" ChangeKey="CK1"/>
                <t:DisplayName>Inbox</t:DisplayName>
                <t:TotalCount>3</t:TotalCount>
                <t:UnreadCount>1</t:UnreadCount>
              </t:Folder>
            </t:Create>
            <t:Create>
              <t:Folder>
                <t:FolderId Id="FLD-SENT" ChangeKey="CK2"/>
                <t:DisplayName>Sent Items</t:DisplayName>
                <t:TotalCount>10</t:TotalCount>
                <t:UnreadCount>0</t:UnreadCount>
              </t:Folder>
            </t:Create>
            <t:Create>
              <t:CalendarFolder>
                <t:FolderId Id="FLD-CAL" ChangeKey="CK3"/>
                <t:DisplayName>Calendar</t:DisplayName>
                <t:TotalCount>5</t:TotalCount>
              </t:CalendarFolder>
            </t:Create>
          </m:Changes>
        </m:SyncFolderHierarchyResponseMessage>
      </m:ResponseMessages>
    </m:SyncFolderHierarchyResponse>
  </soap:Body>
</soap:Envelope>
