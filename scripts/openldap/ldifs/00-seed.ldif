# Mailwoman CI seed for OpenLDAP (bitnami/openldap, LDAP_CUSTOM_LDIF_DIR=/ldifs).
# Deterministic fixtures for the directory-vs-openldap live job (mw-directory,
# plan §13): GAL search, distribution-group expand-before-send, S/MIME cert
# lookup (userCertificate;binary), photo lookup (jpegPhoto), and LDAP-bind auth.
# Base tree: dc=example,dc=com. Admin bind: cn=admin,dc=example,dc=com / adminpassword.

dn: dc=example,dc=com
objectClass: top
objectClass: dcObject
objectClass: organization
o: Example Org
dc: example

dn: ou=people,dc=example,dc=com
objectClass: organizationalUnit
ou: people

dn: ou=groups,dc=example,dc=com
objectClass: organizationalUnit
ou: groups

# Alice — full GAL entry WITH an S/MIME userCertificate;binary + a jpegPhoto.
dn: uid=alice,ou=people,dc=example,dc=com
objectClass: top
objectClass: person
objectClass: organizationalPerson
objectClass: inetOrgPerson
uid: alice
cn: Alice Anderson
sn: Anderson
givenName: Alice
displayName: Alice Anderson
mail: alice@example.com
title: Staff Engineer
o: Example Org
ou: Engineering
telephoneNumber: +1-202-555-0101
userPassword: alicepass
userCertificate;binary:: 
jpegPhoto:: iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAIAAACQd1PeAAAADElEQVR4nGNgYGAAAAAEAAH2FzhVAAAAAElFTkSuQmCC

# Bob — GAL entry, no certificate (exercises the "cert absent" branch).
dn: uid=bob,ou=people,dc=example,dc=com
objectClass: top
objectClass: person
objectClass: organizationalPerson
objectClass: inetOrgPerson
uid: bob
cn: Bob Baker
sn: Baker
givenName: Bob
displayName: Bob Baker
mail: bob@example.com
title: Product Manager
o: Example Org
ou: Product
telephoneNumber: +1-202-555-0102
userPassword: bobpass

# Carol — GAL entry, no certificate.
dn: uid=carol,ou=people,dc=example,dc=com
objectClass: top
objectClass: person
objectClass: organizationalPerson
objectClass: inetOrgPerson
uid: carol
cn: Carol Clark
sn: Clark
givenName: Carol
displayName: Carol Clark
mail: carol@example.com
title: Designer
o: Example Org
ou: Design
telephoneNumber: +1-202-555-0103
userPassword: carolpass

# Distribution groups (groupOfNames) for expand-before-send.
dn: cn=engineering,ou=groups,dc=example,dc=com
objectClass: top
objectClass: groupOfNames
cn: engineering
description: Engineering distribution list
member: uid=alice,ou=people,dc=example,dc=com
member: uid=bob,ou=people,dc=example,dc=com

dn: cn=all-staff,ou=groups,dc=example,dc=com
objectClass: top
objectClass: groupOfNames
cn: all-staff
description: All staff distribution list
member: uid=alice,ou=people,dc=example,dc=com
member: uid=bob,ou=people,dc=example,dc=com
member: uid=carol,ou=people,dc=example,dc=com
